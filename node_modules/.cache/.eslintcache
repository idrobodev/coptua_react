time":1758213079560,"results":"78","hashOfConfig":"47"},{"size":3936,"mtime":1758204004042,"results":"79","hashOfConfig":"47"},{"size":11243,"mtime":1758204004053,"results":"80","hashOfConfig":"47"},{"size":3186,"mtime":1758204004041,"results":"81","hashOfConfig":"47"},{"size":10878,"mtime":1758204004057,"results":"82","hashOfConfig":"47"},{"size":2042,"mtime":1758217384913,"results":"83","hashOfConfig":"47"},{"size":2009,"mtime":1758204004041,"results":"84","hashOfConfig":"47"},{"size":3788,"mtime":1758234607183,"results":"85","hashOfConfig":"47"},{"size":1532,"mtime":1758204004058,"results":"86","hashOfConfig":"47"},{"size":2357,"mtime":1758204004041,"results":"87","hashOfConfig":"47"},{"size":3468,"mtime":1758204004042,"results":"88","hashOfConfig":"47"},{"size":2735,"mtime":1758204004080,"results":"89","hashOfConfig":"47"},{"size":387,"mtime":1758221466400,"results":"90","hashOfConfig":"47"},{"size":262,"mtime":1758221471187,"results":"91","hashOfConfig":"47"},{"filePath":"92","messages":"93","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"94"},"jvuji",{"filePath":"95","messages":"96","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"97","messages":"98","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"94"},{"filePath":"99","messages":"100","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"101","messages":"102","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"103","messages":"104","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"94"},{"filePath":"105","messages":"106","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"u